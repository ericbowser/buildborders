# execute-engrave.com — Next.js + /api email proxy
#
# Prerequisites:
#   1. buildborders built: npm run build
#   2. Next.js running: systemd buildborders.service (port 3000)
#   3. Email API: systemd buildborders-api.service (port 7667)
#   4. TLS: certbot --nginx -d execute-engrave.com

server {
    listen 80;
    listen [::]:80;
    server_name execute-engrave.com www.execute-engrave.com;

    # Email API — MUST be before location /
    location /api/ {
        proxy_pass http://127.0.0.1:7667;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Next.js App Router
    location / {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}

# After editing: sudo nginx -t && sudo systemctl reload nginx
